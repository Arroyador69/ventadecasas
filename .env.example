# https://web3forms.com — gratis, recibes leads por email
WEB3FORMS_ACCESS_KEY=

# Tu número de WhatsApp sin + (ej: 34612345678)
NEXT_PUBLIC_WHATSAPP_NUMBER=34600000000

# ID del vídeo de YouTube (no listado recomendado)
# Ej: si la URL es youtube.com/watch?v=ABC123, el ID es ABC123
NEXT_PUBLIC_VIDEO_YOUTUBE_ID=

# Alternativa: vídeo MP4 en /public/video/tour.mp4
# NEXT_PUBLIC_VIDEO_MP4=/video/tour.mp4

# URL del sitio (para Open Graph)
NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app
